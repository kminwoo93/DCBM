<Page x:Class="SmartOrganApp.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SmartOrganApp"
      xmlns:models="using:SmartOrganApp.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      Background="{ThemeResource BackgroundBrush}">
    <ScrollViewer>
        <utu:AutoLayout
            Spacing="16"
            CornerRadius="21"
            PrimaryAxisAlignment="Center"
            CounterAxisAlignment="Center"
            Padding="42,42"
            Width="395"
            Background="#F6F6F6"
            Margin="4,22,4,4">
            <Image
                Source="/Assets/SmartOrganAppLogo.png"
                Width="250"
                Height="250"
                Stretch="Fill" />
            <TextBlock
                TextAlignment="Center"
                TextWrapping="Wrap"
                Text="SMART Organ"
                FontSize="36"
                FontWeight="Bold"
                utu:AutoLayout.CounterAlignment="Stretch" />
            <TextBlock
                TextAlignment="Center"
                TextWrapping="Wrap"
                FontSize="20"
                Text="Sensing Metabolic, Anti-inflammatory, and Rejection Trends for Organ Health"
                utu:AutoLayout.CounterAlignment="Stretch" />
            <Button
                Width="282"
                Background="#42ABC2"
                CornerRadius="10"
                Padding="10"
                Click="Researcher_Click">
                <TextBlock
                    TextAlignment="Center"
                    Text="Researcher"
                    FontSize="24"
                    Foreground="#F6F6F6"/>
            </Button>

            <Button
                Width="282"
                Background="#0F9D58"
                CornerRadius="10"
                Padding="10"
                Click="GoogleOAuthLoginTest_Click">
                <TextBlock
                    TextAlignment="Center"
                    Text="Google OAuth Login Test"
                    FontSize="20"
                    Foreground="#F6F6F6"/>
            </Button>
            <Button
                Width="282"
                Background="#3268A8"
                CornerRadius="10"
                Padding="10"
                Click="ListLocalCsv_Click">
                <TextBlock
                    TextAlignment="Center"
                    Text="List Local CSV"
                    FontSize="18"
                    Foreground="#F6F6F6"/>
            </Button>
            <Button
                Width="282"
                Background="#7A4AB3"
                CornerRadius="10"
                Padding="10"
                Click="UploadSelectedCsv_Click">
                <TextBlock
                    TextAlignment="Center"
                    Text="Upload Selected"
                    FontSize="18"
                    Foreground="#F6F6F6"/>
            </Button>
            <Button
                Width="282"
                Background="#995C2A"
                CornerRadius="10"
                Padding="10"
                Click="UploadAllCsv_Click">
                <TextBlock
                    TextAlignment="Center"
                    Text="Upload All CSV"
                    FontSize="18"
                    Foreground="#F6F6F6"/>
            </Button>
            <TextBlock
                x:Name="GoogleAuthStatusText"
                Text="Google auth status will be shown here."
                TextWrapping="Wrap"
                FontSize="14"
                Width="282"
                Foreground="#222222" />

            <ListView
                x:Name="LocalCsvListView"
                Width="320"
                Height="240"
                SelectionMode="Single"
                ItemsSource="{Binding LocalCsvFiles}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LocalCsvFileInfo">
                        <StackPanel Padding="8" Spacing="2">
                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding FullPath}" TextWrapping="WrapWholeWords" FontSize="12"/>
                            <TextBlock Text="{Binding SizeBytes}" FontSize="12"/>
                            <TextBlock Text="{Binding ModifiedTimeUtc}" FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                x:Name="DriveUploadStatusText"
                Text="Drive upload status will be shown here."
                TextWrapping="WrapWholeWords"
                FontSize="14"
                Width="320"
                Foreground="#222222" />
        </utu:AutoLayout>
    </ScrollViewer>
</Page>
