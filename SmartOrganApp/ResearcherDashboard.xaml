        <x:String x:Key="Icon_Icon_Tabler_Icon_Chevron_Down">F1 M 0 0 L 3.5 3.5 L 7 0</x:String>
        <x:String x:Key="Icon_Size_48">F1 M 10.208333015441895 20.41666603088379 L 0 10.208333015441895 L 10.208333015441895 0 M 20.41666603088379 10.208333015441895 L 0 10.208333015441895</x:String>
    </Page.Resources>

    <ScrollViewer VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">

        <utu:AutoLayout Orientation="Vertical" Spacing="6" CornerRadius="21" Margin="4,22,4,4" CounterAxisAlignment="Stretch">
            //Back button
            <utu:AutoLayout Height="40" Orientation="Horizontal" CounterAxisAlignment="Center" Justify="SpaceBetween" Margin="4,0,4,0">
                <Button Background="Transparent"  BorderThickness="0" Click="ExitButton_Click" >
                    <PathIcon Data="{StaticResource Icon_Size_48}" Foreground="black"/>
                </Button>
                <TextBlock TextAlignment="End" Text="Researcher" FontSize="20"/>
            </utu:AutoLayout>
            //Device Scan part
            <Grid Height="40" Margin="4,0,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Left Device Scan button -->
                <Border Grid.Column="0" CornerRadius="12" Background="#42ABC2" Height="30">
                    <Button Background="Transparent" Click="DeviceScanButton_Click" BorderThickness="0" HorizontalAlignment="Center">
                        <TextBlock Text="Device Scan" FontSize="16" Foreground="#F6F6F6" TextAlignment="Center"/>
                    </Button>
                </Border>
                <!-- Right text + underline (use remaining width) -->
                <Border Grid.Column="1" BorderBrush="#42ABC2" BorderThickness="0,0,0,1" VerticalAlignment="Bottom" Margin="10,0,0,7">
                    <TextBlock x:Name="ConnectedBLEName" Text="Not connected" FontSize="16" Foreground="Gray" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                </Border>
            </Grid>
            //Liver ID part
            <utu:AutoLayout Height="30" Orientation="Horizontal" CounterAxisAlignment="Center" Justify="SpaceBetween" Margin="4,0,4,0">
                <utu:AutoLayout Orientation="Horizontal" CounterAxisAlignment="Center" Spacing="10" Margin="20,0,0,0">
                    <PathIcon Data="{StaticResource Icon_Account_Circle}" Foreground="Black"/>
                    <TextBlock x:Name="LiverID" TextWrapping="Wrap" Text="Liver ID" Foreground="Black"/>
                </utu:AutoLayout>
                <Button x:Name="LiverIDButton" Background="Transparent"  BorderThickness="0" Click="LiverIDButton_Click" >
                    <PathIcon Data="{StaticResource Icon_Arrow_Right}" Foreground="Black"/>
                </Button>
            </utu:AutoLayout>
            <!-- Opens the Calibration screen (includes PBS rinse + all calibration steps) -->
            <Button x:Name="CalibrationButton"
                    Background="#C0D0D4"
                    CornerRadius="0"
                    Click="CalibrationButton_Click">
                <utu:AutoLayout Orientation="Horizontal" Spacing="6"
                                CounterAxisAlignment="Center" Justify="SpaceBetween">
                    <TextBlock Text="Calibration" FontSize="16" Foreground="Black"/>
                    <PathIcon Data="{StaticResource Icon_Arrow_Right}"
                              Foreground="Black" Margin="0,0,4,0"/>
                </utu:AutoLayout>
            </Button>
            <utu:Divider Foreground="#42ABC2"/>
            //Start + Stop Pump part
            <Button x:Name="StartPumpButton" Background="#C0D0D4" Click="StartPumpButton_Click" CornerRadius="0" >
                <utu:AutoLayout Orientation="Horizontal" Spacing="6" CounterAxisAlignment="Center" Justify="SpaceBetween">
                    <TextBlock x:Name="StartPumpText" Text="Start pump" FontSize="16" Foreground="Black"/>
                    <PathIcon x:Name="StartPumpArrow" Data="{StaticResource Icon_Arrow_Right}" Foreground="Black" Margin="0,0,4,0"/>
                </utu:AutoLayout>
            </Button>
            //Start + Stop Monitoring part
            <Button x:Name="StartStopButton" Background="#C0D0D4" Click="StartStopButton_Click" CornerRadius="0" >
                <utu:AutoLayout Orientation="Horizontal" Spacing="6" CounterAxisAlignment="Center" Justify="SpaceBetween">
                    <TextBlock x:Name="StartStopText" Text="Start monitoring" FontSize="16" Foreground="Black"/>
                    <PathIcon x:Name="StartStopArrow" Data="{StaticResource Icon_Arrow_Right}" Foreground="Black" Margin="0,0,4,0"/>
                </utu:AutoLayout>
            </Button>
            //Glucose Lactate pH button part
            <utu:AutoLayout Orientation="Horizontal" CounterAxisAlignment="Center" Justify="SpaceBetween" Spacing="10" Margin="10,0,10,0">
                <Button x:Name="GlucoseButton" Background="#45B3CB" Click="GlucoseButton_Click" CornerRadius="10" Width="110" >
                    <utu:AutoLayout Orientation="Vertical" PrimaryAxisAlignment="Center" CounterAxisAlignment="Start" Justify="SpaceBetween" Padding="0,15,0,15">
                        <Image x:Name="GlucoseImage" Source="/Assets/Icons/GlucoseIcon.png" Width="50" Height="50" Stretch="UniformToFill"></Image>
                        <TextBlock Text="Glucose" TextWrapping="Wrap" Foreground="White" Margin="0,5,0,0"/>
                    </utu:AutoLayout>
                </Button>
                <Button x:Name="LactateButton" Background="#ED7390" Click="LactateButton_Click" CornerRadius="10" Width="110" >
                    <utu:AutoLayout Orientation="Vertical" PrimaryAxisAlignment="Center" CounterAxisAlignment="Start" Justify="SpaceBetween" Padding="0,15,0,15">
                        <Image x:Name="LactateImage" Source="/Assets/Icons/LactateIcon.png" Width="50" Height="50" Stretch="UniformToFill"></Image>
                        <TextBlock Text="Lactate" TextWrapping="Wrap" Foreground="White" Margin="0,5,0,0"/>
                    </utu:AutoLayout>
                </Button>
                <Button x:Name="pHButton" Background="#E59850" Click="pHButton_Click" CornerRadius="10" Width="110" >
                    <utu:AutoLayout Orientation="Vertical" PrimaryAxisAlignment="Center" CounterAxisAlignment="Start" Justify="SpaceBetween" Padding="0,15,0,15">
                        <Image x:Name="pHImage" Source="/Assets/Icons/pHIcon.png" Width="50" Height="50" Stretch="UniformToFill"></Image>
                        <TextBlock Text="pH" TextWrapping="Wrap" Foreground="White" Margin="0,5,0,0"/>
                    </utu:AutoLayout>
                </Button>
            </utu:AutoLayout>
            //Raw data graph part
            <utu:AutoLayout Orientation="Horizontal" Justify="SpaceBetween" CounterAxisAlignment="Center">
                <TextBlock Text="Raw data" FontSize="18" FontWeight="SemiBold"/>
                <!-- Time selection dropdown -->
                <ComboBox x:Name="TimePointComboBox"
              Width="100"
              PlaceholderText="Select time"
              SelectionChanged="TimePointComboBox_SelectionChanged" />
            </utu:AutoLayout>
            //Graph part
            <Border Height="200" Background="#F6F6F6" CornerRadius="12" Padding="8">
                <Grid>
                    <ScottPlot:WinUIPlot x:Name="WinUIPlot1"/>
                </Grid>
            </Border>

            <!-- ══ CONCENTRATION × TIME — 6 channel graphs ══════════════════ -->
            <TextBlock Text="Channel Concentration × Time" FontSize="16"
                       FontWeight="SemiBold" Margin="0,8,0,0"/>

            <!-- Row 1: CH1 Glucose-P + CH5 Glucose-B -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="180" Background="#F6F6F6" CornerRadius="12" Padding="4">
                    <ScottPlot:WinUIPlot x:Name="ChPlot1"/>
                </Border>
                <Border Grid.Column="2" Height="180" Background="#F6F6F6" CornerRadius="12" Padding="4">
                    <ScottPlot:WinUIPlot x:Name="ChPlot4"/>
                </Border>
            </Grid>

            <!-- Row 2: CH2 Lactate-P + CH6 Lactate-B -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="180" Background="#F6F6F6" CornerRadius="12" Padding="4">
                    <ScottPlot:WinUIPlot x:Name="ChPlot2"/>
                </Border>
                <Border Grid.Column="2" Height="180" Background="#F6F6F6" CornerRadius="12" Padding="4">
                    <ScottPlot:WinUIPlot x:Name="ChPlot5"/>
                </Border>
            </Grid>

            <!-- Row 3: CH3 pH-P + CH7 pH-B -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="180" Background="#F6F6F6" CornerRadius="12" Padding="4">
                    <ScottPlot:WinUIPlot x:Name="ChPlot3"/>
                </Border>
                <Border Grid.Column="2" Height="180" Background="#F6F6F6" CornerRadius="12" Padding="4">
                    <ScottPlot:WinUIPlot x:Name="ChPlot6"/>
                </Border>
            </Grid>

            <utu:AutoLayout>
                <TextBlock x:Name="CurrentValueTextBlock" Text="No value" FontSize="14" Foreground="Gray"/>
            </utu:AutoLayout>
        </utu:AutoLayout>
    </ScrollViewer>
</Page>
