 13702                           
 13703                           ;Config register CONFIG2 @ 0x8008
 13704                           ;	Master Clear Enable bit
 13705                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 13706                           ;	Power-up Timer Selection bits
 13707                           ;	PWRTS = PWRT_64, PWRT set at 64 ms
 13708                           ;	WDT Operating Mode bits
 13709                           ;	WDTE = OFF, WDT disabled; SEN is ignored
 13710                           ;	Brown-out Reset Enable bits
 13711                           ;	BOREN = ON, Brown-out Reset Enabled, SBOREN bit is ignored
 13712                           ;	Brown-out Reset Voltage Selection bit
 13713                           ;	BORV = LO, Brown-out Reset Voltage (VBOR) set to 1.9V
 13714                           ;	PPSLOCKED One-Way Set Enable bit
 13715                           ;	PPS1WAY = OFF, The PPSLOCKED bit can be set and cleared as needed (unlocking sequence 
      +                          is required)
 13716                           ;	Stack Overflow/Underflow Reset Enable bit
