 13689                           ;Config register CONFIG1 @ 0x8007
 13690                           ;	External Oscillator Mode Selection bits
 13691                           ;	FEXTOSC = OFF, Oscillator not enabled
 13692                           ;	Power-up Default Value for COSC bits
 13693                           ;	RSTOSC = HFINTOSC_32MHZ, HFINTOSC (32 MHz)
 13694                           ;	Clock Out Enable bit
 13695                           ;	CLKOUTEN = OFF, CLKOUT function is disabled; I/O function on RA6
 13696                           ;	VDD Range Analog Calibration Selection bit
 13697                           ;	VDDAR = LO, Internal analog systems are calibrated for operation between VDD = 1.8V - 
      +                          3.6V
 13698     8007                     	org	32775
 13699     8007  2FCD               	dw	12237
 13700                           
 13701                           ;Config register CONFIG2 @ 0x8008
 13702                           ;	Master Clear Enable bit
 13703                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 13704                           ;	Power-up Timer Selection bits
 13705                           ;	PWRTS = PWRT_64, PWRT set at 64 ms
 13706                           ;	WDT Operating Mode bits
 13707                           ;	WDTE = OFF, WDT disabled; SEN is ignored
 13708                           ;	Brown-out Reset Enable bits
 13709                           ;	BOREN = ON, Brown-out Reset Enabled, SBOREN bit is ignored
 13710                           ;	Brown-out Reset Voltage Selection bit
 13711                           ;	BORV = LO, Brown-out Reset Voltage (VBOR) set to 1.9V
 13712                           ;	PPSLOCKED One-Way Set Enable bit
 13713                           ;	PPS1WAY = OFF, The PPSLOCKED bit can be set and cleared as needed (unlocking sequence 
      +                          is required)
 13714                           ;	Stack Overflow/Underflow Reset Enable bit
 13715                           ;	STVREN = ON, Stack Overflow or Underflow will cause a reset
 13716     8008                     	org	32776
 13717     8008  37E5               	dw	14309
 13718                           
 13719                           ;Config register CONFIG4 @ 0x800A
 13720                           ;	Boot Block Size Selection bits
 13721                           ;	BBSIZE = BB512, 512 words boot block size
 13722                           ;	Boot Block Enable bit
 13723                           ;	BBEN = OFF, Boot Block is disabled
 13724                           ;	SAF Enable bit
 13725                           ;	SAFEN = OFF, SAF is disabled
 13726                           ;	Application Block Write Protection bit
 13727                           ;	WRTAPP = OFF, Application Block is not write-protected
 13728                           ;	Boot Block Write Protection bit
 13729                           ;	WRTB = OFF, Boot Block is not write-protected
 13730                           ;	Configuration Registers Write Protection bit
 13731                           ;	WRTC = OFF, Configuration Registers are not write-protected
 13732                           ;	Storage Area Flash (SAF) Write Protection bit
 13733                           ;	WRTSAF = OFF, SAF is not write-protected
 13734                           ;	Low Voltage Programming Enable bit
